# Copy to `.env` / `.env.local` and fill in real values (do not commit secrets).

# Database — app database name (avoid using the system `postgres` database)
# Create once: `psql postgresql://postgres:...@127.0.0.1:5432/postgres -c "CREATE DATABASE mmoney;"`
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/mmoney

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Set to 1 after configuring **organization** plans in Clerk Billing (otherwise omit — pricing hides org tab).
# NEXT_PUBLIC_CLERK_ORG_BILLING_ENABLED=1
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
# Optional: Bearer secret for POST /api/billing/sync-plans-from-clerk (pull plans from Clerk into DB).
# BILLING_PLAN_SYNC_SECRET=
# Optional: set to 1 to skip Clerk plan list on every subscription.* webhook (use cron + route above instead).
# BILLING_DISABLE_CLERK_PLAN_SYNC_ON_SUBSCRIPTION_WEBHOOK=1

# Python Processing Service — used for both image enhancement and video enhancement
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_API_KEY=

STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_PUBLIC_BASE_URL=
# Set to 1 if R2 rejects S3 ACL headers (Cloudflare R2 often does)
# STORAGE_DISABLE_ACL=1

WEBHOOK_SECRET=
