# ── App ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Change this to a long random string in production
API_SECRET_KEY=your-secret-key-here

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage (Cloudflare R2) ──────────────────────────────────
# Get these from Cloudflare Dashboard → R2 → Manage API tokens
STORAGE_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-r2-access-key
STORAGE_SECRET_KEY=your-r2-secret-key
STORAGE_BUCKET=pixelai-outputs
STORAGE_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev   # or your custom domain

# ── Webhook (Next.js notified when job finishes) ─────────────
# From Docker: use host.docker.internal (Mac/Win) so the container reaches Next on your machine
WEBHOOK_URL=http://host.docker.internal:3000/api/webhooks/process
WEBHOOK_SECRET=your-webhook-secret

# ── Processing limits ────────────────────────────────────────
MAX_IMAGE_SIZE_MB=50
MAX_UPSCALE_MP=512
MODEL_CACHE_DIR=/app/models
# Mac Docker: use 0.15–0.25 for bearable wait; 0.5 can exceed 10 min on CPU
MAX_INPUT_MP_CPU=0.2
# Extra shrink when scale is 4×/8×/16× on CPU (avoids frontend/worker timeout). 0 = disable
MAX_INPUT_MP_CPU_SCALE_GE_4=0.18
# UI "Auto" size → output scale (1–4). Default 2 = fast x2 weights; 4 = old behaviour (4×, slower)
AUTO_UPSCALE_SCALE=2
SKIP_FACE_ENHANCE_ON_CPU=true
# When Old Photo on CPU skips GFPGAN — stronger Light AI (0–100) so output still changes
OLD_PHOTO_CPU_LIGHT_INTENSITY=80
# true = never LANCZOS-stretch beyond neural net output on CPU (avoids “big but still soft”)
CPU_AVOID_LANCZOS_UPSCALE=true
INFERENCE_TIMEOUT_S=600
# Full job (download + AI + upload); after this Redis gets status=error
# 4× jobs on CPU need headroom; Next.js poll is ~32 min — match or exceed
JOB_PIPELINE_TIMEOUT_S=1800
JPEG_OUTPUT_QUALITY=90
