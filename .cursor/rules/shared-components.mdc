## UI Primitives — `src/components/ui/`

### `GlassCard.tsx` — dark glass card/panel

```tsx
export const GlassCard = (props: {
  children: React.ReactNode;
  className?: string;
  glow?: boolean;           // adds brand glow — use only on featured cards
  padding?: 'sm' | 'md' | 'lg';
}) => {
  const paddings = { sm: 'p-4', md: 'p-6', lg: 'p-8' };
  return (
    <div
      className={`rounded-card border border-brand/20 bg-surface shadow-card ${paddings[props.padding ?? 'md']} ${props.className ?? ''}`}
      style={props.glow ? { boxShadow: 'var(--shadow-card), var(--shadow-brand)' } : undefined}
    >
      {props.children}
    </div>
  );
};
```

---

> **Badge/Chip** → use `<Chip>` from `@heroui/react/chip`. Do not create a separate `Badge.tsx`.

---

### `GradientText.tsx` — violet→pink gradient text

```tsx
export const GradientText = (props: { children: React.ReactNode; className?: string }) => (
  <span
    className={`bg-clip-text text-transparent ${props.className ?? ''}`}
    style={{ backgroundImage: 'var(--gradient-text)' }}
  >
    {props.children}
  </span>
);
```

---

### `SectionHeading.tsx` — standard section title block

Use for: eyebrow chip + h2 + subtitle

```tsx
import { Chip } from '@heroui/react/chip';

export const SectionHeading = (props: {
  eyebrow?: string;
  title: React.ReactNode;   // accepts <GradientText> inside
  subtitle?: string;
  centered?: boolean;
}) => (
  <div className={`max-w-2xl ${props.centered ? 'mx-auto text-center' : ''}`}>
    {props.eyebrow && (
      <Chip color="secondary" variant="bordered" size="sm" className="mb-4">
        {props.eyebrow}
      </Chip>
    )}
    <h2 className="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
      {props.title}
    </h2>
    {props.subtitle && (
      <p className="mt-4 text-lg leading-relaxed text-muted">
        {props.subtitle}
      </p>
    )}
  </div>
);
```

