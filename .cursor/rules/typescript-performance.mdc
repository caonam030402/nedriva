# TypeScript & Performance Rules

## TypeScript

### No `any`

Never use `any`. Use `unknown` + narrowing, or explicit type annotation.

```typescript
// ❌
function process(data: any) {}

// ✅
function process(data: unknown) {
  if (typeof data === 'string') { /* safe */ }
}
// or
function process(data: SpecificType) {}
```

### `type` over `interface`

Use `type` for object shapes. Reserve `interface` for things that may be extended.

```typescript
// ✅
type UserProfile = {
  id: string;
  name: string;
};

// ✅ if extension is intended
interface Config {
  baseUrl: string;
}
```

### Discriminated unions over optional fields

```typescript
// ❌ — fragile, need multiple undefined checks
type Result = {
  data?: UserProfile;
  error?: string;
  loading?: boolean;
};

// ✅ — exhaustive, TypeScript narrows automatically
type Result =
  | { status: 'idle' }
  | { status: 'loading' }
  | { status: 'success'; data: UserProfile }
  | { status: 'error'; error: string };
```

### Prefer inference, annotate when ambiguous

```typescript
// ✅ TypeScript infers: () => Promise<EnhancerHistoryItem[]>
async function getHistory() { return []; }

// ✅ When inference fails or is wrong — annotate
const result: string = await someAsyncFn(); // explicit needed
```

### Zod types

```typescript
// ✅ Define Zod schema, infer TypeScript type from it
import { z } from 'zod';
import type * as z from 'zod';

const HistorySchema = z.object({
  id: z.string().uuid(),
  createdAt: z.coerce.date(),
  operation: z.enum(['upscale', 'enhance', 'restore']),
});

export type HistoryRow = z.infer<typeof HistorySchema>;
// ✅ HistoryRow is: { id: string; createdAt: Date; operation: 'upscale' | 'enhance' | 'restore' }
```

### Options object for 3+ params

```typescript
// ❌
function submitJob(userId: string, operation: string, creditCost: number, inputKey: string, outputBucket: string) {}

// ✅
function submitJob(opts: {
  userId: string;
  operation: string;
  creditCost: number;
  inputKey: string;
  outputBucket: string;
}) {}
```

### Named exports only

```typescript
// ❌
export default function HomePage() {}
export default class ApiClient {}

// ✅ — allows tree-shaking and easier refactoring
export function HomePage() {}
export class ApiClient {}
```

Exception: Next.js `page.tsx` and `layout.tsx` can use default exports per convention.

### Exhaustive switch

```typescript
// ❌ — TypeScript won't error if a new status is added
switch (job.status) {
  case 'queued': return <QueuedIcon />;
  case 'processing': return <Spinner />;
  case 'done': return <DoneIcon />;
}

// ✅ — TypeScript errors if a case is missing
const iconMap = {
  queued: <QueuedIcon />,
  processing: <Spinner />,
  done: <DoneIcon />,
  error: <ErrorIcon />,
} as const satisfies Record<TJobStatus, ReactNode>;
```

