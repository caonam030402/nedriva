## Common Patterns for This App

### Button — all states
```tsx
import { Button } from '@heroui/react/button';

<Button color="primary" radius="full" className="font-semibold">Get Started</Button>
<Button variant="bordered" radius="full" color="primary">Learn More</Button>
<Button color="primary" isLoading>Processing…</Button>
<Button color="primary" isDisabled={jobStatus === 'processing'}>Upscale</Button>
```

### Modal — confirm action, result preview
```tsx
import { Modal, ModalContent, ModalHeader, ModalBody, ModalFooter, useDisclosure } from '@heroui/react/modal';

const { isOpen, onOpen, onOpenChange } = useDisclosure();

<Modal isOpen={isOpen} onOpenChange={onOpenChange} backdrop="blur">
  <ModalContent>
    {(onClose) => (
      <>
        <ModalHeader>Confirm Processing</ModalHeader>
        <ModalBody>This will use 2 credits. You have 18 remaining.</ModalBody>
        <ModalFooter>
          <Button variant="bordered" onPress={onClose}>Cancel</Button>
          <Button color="primary" onPress={onClose}>Confirm</Button>
        </ModalFooter>
      </>
    )}
  </ModalContent>
</Modal>
```

### Chip — job status, credit cost
```tsx
import { Chip } from '@heroui/react/chip';

<Chip color="default"   variant="flat"     size="sm">Pending</Chip>
<Chip color="primary"   variant="flat"     size="sm">Processing…</Chip>
<Chip color="success"   variant="flat"     size="sm">Completed</Chip>
<Chip color="danger"    variant="flat"     size="sm">Failed</Chip>
<Chip color="secondary" variant="bordered" startContent={<span>✦</span>}>2 credits</Chip>
```

### Alert — inline status messages
```tsx
import { Alert } from '@heroui/react/alert';

<Alert color="success" title="Processing complete!" description="Your image is ready to download." />
<Alert color="danger"  title="Processing failed"    description="File too large or unsupported format." />
<Alert color="warning" title="Low credits"          description="You only have 2 credits remaining." />
```

### Toast — auto-dismiss notifications
```tsx
import { ToastProvider, addToast } from '@heroui/react/toast';

// Add once in root layout
<ToastProvider />

// Call from anywhere
addToast({ title: 'Added to queue',       color: 'primary' });
addToast({ title: 'Upscale complete!',    color: 'success' });
addToast({ title: 'Processing failed',    color: 'danger', timeout: 8000 });
```

### Select — output format, scale factor
```tsx
import { Select, SelectItem } from '@heroui/react/select';

<Select label="Scale factor" variant="bordered" color="primary" defaultSelectedKeys={['2x']}>
  <SelectItem key="2x">2x — fast, 1 credit</SelectItem>
  <SelectItem key="4x">4x — 2 credits</SelectItem>
  <SelectItem key="8x">8x — 4 credits</SelectItem>
  <SelectItem key="16x">16x — up to 512MP, 8 credits</SelectItem>
</Select>
```

### Slider — enhancement level, quality
```tsx
import { Slider } from '@heroui/react/slider';

<Slider
  label="Enhancement level"
  color="primary"
  step={10}
  minValue={0}
  maxValue={100}
  defaultValue={70}
  className="max-w-md"
/>
```

### Table — job history
```tsx
import { Table, TableHeader, TableBody, TableColumn, TableRow, TableCell } from '@heroui/react/table';

<Table aria-label="Job history" selectionMode="none">
  <TableHeader>
    <TableColumn>Image</TableColumn>
    <TableColumn>Operation</TableColumn>
    <TableColumn>Status</TableColumn>
    <TableColumn>Date</TableColumn>
    <TableColumn>Credits</TableColumn>
  </TableHeader>
  <TableBody>
    {jobs.map(job => (
      <TableRow key={job.id}>
        <TableCell>...</TableCell>
      </TableRow>
    ))}
  </TableBody>
</Table>
```

### Skeleton — loading placeholder
```tsx
import { Skeleton } from '@heroui/react/skeleton';

<Skeleton className="rounded-[var(--radius-lg)]">
  <div className="h-48 w-full" />
</Skeleton>
```

### Tabs — switch between views or operations
```tsx
import { Tabs, Tab } from '@heroui/react/tabs';

<Tabs color="primary" variant="underlined" aria-label="Operations">
  <Tab key="upscale"   title="Upscale" />
  <Tab key="enhance"   title="Enhance" />
  <Tab key="restore"   title="Restore" />
  <Tab key="remove-bg" title="Remove BG" />
</Tabs>
```

### Pagination — job history, gallery
```tsx
import { Pagination } from '@heroui/react/pagination';

<Pagination total={totalPages} color="primary" page={page} onChange={setPage} />
```

